# Application
NODE_ENV=development
PORT=3000

# CORS — "*" for any origin, or a comma-separated list (e.g. https://app.com,https://admin.app.com)
CORS_ORIGIN=*

# Database — Postgres connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app

# Redis — caching and OTP storage
REDIS_URL=redis://localhost:6379

# Email — from address (dev uses a console "log" transport; wire a real provider in lib/mailer.ts)
EMAIL_FROM=no-reply@example.com

# Auth — use long random strings in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret
JWT_ACCESS_EXP=15m
JWT_REFRESH_EXP=7d
