# Application
NODE_ENV=development
PORT=3000
# Product name shown in transactional email templates
APP_NAME=App

# CORS — "*" for any origin, or a comma-separated list (e.g. https://app.com,https://admin.app.com)
CORS_ORIGIN=*

# Logging — trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# Rate limiting — set true behind a proxy/load balancer to trust X-Forwarded-For
TRUST_PROXY=false

# Request limits — max body size (bytes, 413 if exceeded) and idle timeout (s)
MAX_BODY_SIZE=1048576
REQUEST_IDLE_TIMEOUT=30

# Database — Postgres connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app
# Connection pool (postgres.js): size to DB max_connections across all replicas
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30
DB_CONNECT_TIMEOUT=30
# Per-query timeout in ms (0 = off) — cancels runaway queries server-side
DB_STATEMENT_TIMEOUT=30000

# Redis — caching, OTP storage, and the job queue (BullMQ)
REDIS_URL=redis://localhost:6379

# Job queue driver: "redis" (BullMQ worker) or "sync" (run jobs inline; tests use this)
QUEUE_DRIVER=redis

# Ops alerts — webhook (Slack/Discord/PagerDuty-style JSON POST) for critical
# events, e.g. a queue job exhausting all its retries. Empty = disabled.
ALERT_WEBHOOK_URL=

# Days to keep audit_logs rows (purged daily by the worker); 0 = keep forever
AUDIT_RETENTION_DAYS=90

# Email transport: "auto" (log in dev, smtp in prod), or force "log" / "smtp".
# In development emails are logged to the console by default; set MAIL_TRANSPORT=smtp
# (with Mailtrap creds below) to actually send while developing.
MAIL_TRANSPORT=auto
EMAIL_FROM=no-reply@example.com
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Auth — use a long random string in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me-to-a-long-random-secret
# Zero-downtime secret rotation: deploy the new JWT_SECRET with the old one
# here; drop it after JWT_ACCESS_EXP has passed. Empty = disabled.
JWT_SECRET_PREVIOUS=
JWT_ACCESS_EXP=15m
JWT_REFRESH_EXP=7d
# Refresh-token transport: "bearer" (token in the JSON body) or "cookie"
# (httpOnly cookie; set a restricted CORS_ORIGIN in production)
AUTH_TRANSPORT=bearer
# Mandatory email verification — when true, protected routes return 403
# EMAIL_NOT_VERIFIED until the user verifies (registration auto-emails the OTP)
REQUIRE_VERIFIED_EMAIL=false

# Seed admin (used by `bun run db:seed`) — set a real password before seeding
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=
