{
  "name": "app",
  "version": "1.0.50",
  "overrides": {
    "@opentelemetry/sdk-node": "^0.217.0",
    "protobufjs": "^8.6.3"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "worker": "bun run src/worker.ts",
    "worker:dev": "bun run --watch src/worker.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "build": "bun build --compile --minify --target bun --outfile server src/index.ts",
    "build:worker": "bun build --compile --minify --target bun --outfile worker src/worker.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.4",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "@elysiajs/opentelemetry": "^1.4.11",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "bullmq": "^5.78.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-typebox": "^0.3.3",
    "elysia": "^1.4.28",
    "elysia-rate-limit": "^4.6.2",
    "jose": "^6.2.3",
    "nodemailer": "^8.0.10",
    "otpauth": "^9.5.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "prom-client": "^15.1.3",
    "rotating-file-stream": "^3.2.9",
    "sanitize-html": "^2.17.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/nodemailer": "^8.0.0",
    "@types/sanitize-html": "^2.16.1",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3"
  },
  "module": "src/index.js"
}
